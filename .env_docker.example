LIBRE_LIBROS_SECRET_KEY=please-change-this
LIBRE_LIBROS_DATABASE_URL=sqlite:///./data/libre_libros.db
LIBRE_LIBROS_HOST=0.0.0.0
LIBRE_LIBROS_PORT=8000
LIBRE_LIBROS_REPOS_ROOT=/app/data
LIBRE_LIBROS_EXAMPLE_REPO_PATH=/app/data/repo
LIBRE_LIBROS_INIT_ADMIN_EMAIL=admin@example.com
LIBRE_LIBROS_INIT_ADMIN_PASSWORD=admin12345
LIBRE_LIBROS_INIT_ADMIN_NAME=Administrador
LIBRE_LIBROS_WAIT_FOR_RUNTIME_CONFIG=true
LIBRE_LIBROS_RUNTIME_CONFIG_PATH=/app/data/debug/gitlab-runtime.env

# Optional Google sign-in
LIBRE_LIBROS_GOOGLE_CLIENT_ID=
LIBRE_LIBROS_GOOGLE_CLIENT_SECRET=

# Optional generic OIDC
LIBRE_LIBROS_GENERIC_OIDC_ENABLED=false
LIBRE_LIBROS_GENERIC_OIDC_NAME=SSO
LIBRE_LIBROS_GENERIC_OIDC_SERVER_METADATA_URL=
LIBRE_LIBROS_GENERIC_OIDC_CLIENT_ID=
LIBRE_LIBROS_GENERIC_OIDC_CLIENT_SECRET=

# Optional GitHub sign-in
LIBRE_LIBROS_GITHUB_OAUTH_ENABLED=false
LIBRE_LIBROS_GITHUB_OAUTH_CLIENT_ID=
LIBRE_LIBROS_GITHUB_OAUTH_CLIENT_SECRET=
LIBRE_LIBROS_GITHUB_OAUTH_NAME=GitHub

# GitLab runtime bootstrap values are injected into /app/data/debug/gitlab-runtime.env
LIBRE_LIBROS_EXTERNAL_AUTH_ONLY=false
LIBRE_LIBROS_GITLAB_ENABLED=false
LIBRE_LIBROS_GITLAB_INTERNAL_URL=
